# site_Brundage.env -- per-site settings for the Brundage deployment.
#
# Simply re-name this file to config/site.env on the Brundage PC
#
# --- storage ---
MOUNT=/mnt/snowData                  # data mount point (mountpoint check; used when REQUIRE_MOUNT=1)
DATA_DIR=/mnt/snowData/SDR/Data      # capture output root (passed to cryosoop as --save-loc)
REQUIRE_MOUNT=1                      # DATA_DIR must be under a dedicated mount ($MOUNT)
MIN_FREE_GB=8                        # abort below this much free space [GB]
NVME_MIN_MBPS=400                    # pre-flight write-throughput floor [MB/s]

# --- transfer (off: Brundage is rsync-pulled from an external VM) ---
# TRANSFER_DIR=                      # set to relocate finished runs after each capture
TRANSFER_MODE=move                   # move | copy (used only when TRANSFER_DIR is set)

# --- run behavior ---
RX_TIMEOUT_SEC=1200                  # OS timeout around the WHOLE sequence [s] (>= 2x expected)
REBOOT_ON_FAIL=1                     # 1 = reboot on fatal rc (production); set 0 during bench bring-up
DEFAULT_GOV=ondemand                 # CPU governor restored after the run
# CRYOSOOP_BIN=/home/SDR/CryoSoOp/build/cryosoop        # optional; autodetected if unset
# CONFIG=/home/SDR/CryoSoOp/config/radiometer_B210.yaml # optional; defaults to repo copy

# --- BeagleBone cal switch (bbb_set_state.sh) ---
BBB_HOST=root@192.168.1.101          # ssh target; needs passwordless key auth
BBB_CONNECT_TIMEOUT=15               # ssh ConnectTimeout [s]
GPIO_PINS="49 115 27"                # cal-switch GPIO pins, order matters
NL_VALS="0 0 0"                      # NL (Noise+Load)
L_VALS="0 0 1"                       # L  (Load)
SIGNAL_VALS="1 1 0"                  # Signal (also the end-of-run restore state)
