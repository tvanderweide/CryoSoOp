# site_CSSL.env -- per-site settings for the CSSL (cs-snowlab) deployment.
#
# Simply re-name this file to config/site.env on the CSSL PC
#
# --- storage (record local, then transfer to the big disk -- CSSL's last-season pattern) ---
# Last season CSSL recorded to the internal drive (~/Desktop/Data) and then moved
# finished files to the external HDD /media/cs-snowlab/cssl-data-1/DataPBand.
# cryosoop keeps that two-step flow: it records to DATA_DIR, and radiometer_run.sh
# transfers each finished run to TRANSFER_DIR afterward (see "--- transfer ---" below).
#
# REQUIRE_MOUNT=0 because DATA_DIR is a plain dir on the rootfs, not its own mount --
# the wrapper skips the mountpoint check and runs the free-space/throughput checks on
# DATA_DIR instead. (MOUNT is unused when REQUIRE_MOUNT=0.)
REQUIRE_MOUNT=0
DATA_DIR=/home/cs-snowlab/Desktop/Data           # record here (same internal drive as last season)
MIN_FREE_GB=8                                     # abort below this much free space [GB]
# CAUTION: NVME_MIN_MBPS is a pre-flight write-throughput floor checked on DATA_DIR's
# drive. The internal Desktop drive is unlikely to sustain 400 MB/s; lower it to match
# (e.g. 80) or set 0 to effectively skip -- otherwise the probe aborts every run.
NVME_MIN_MBPS=80                                  # write-throughput floor on the internal drive [MB/s]

# --- transfer (post-collection relocation to the external HDD) ---
TRANSFER_DIR=/media/cs-snowlab/cssl-data-1/DataPBand  # move finished runs here after each capture
TRANSFER_MODE=move                                    # move = free the internal drive (copy verified first)

# --- run behavior ---
RX_TIMEOUT_SEC=1200                  # OS timeout around the WHOLE sequence [s] (>= 2x expected)
REBOOT_ON_FAIL=1                     # 1 = reboot on fatal rc (production); set 0 during bench bring-up
DEFAULT_GOV=ondemand                 # CPU governor restored after the run
# CRYOSOOP_BIN=/home/cs-snowlab/CryoSoOp/build/cryosoop        # optional; autodetected if unset
# CONFIG=/home/cs-snowlab/CryoSoOp/config/radiometer_B210.yaml # optional; defaults to repo copy

# --- BeagleBone cal switch (bbb_set_state.sh) ---
BBB_HOST=root@192.168.0.25           # CSSL BBB ssh target (was 192.168.1.101 at Brundage); needs passwordless key auth
BBB_CONNECT_TIMEOUT=15               # ssh ConnectTimeout [s]
GPIO_PINS="49 115 27"                # cal-switch GPIO pins (same wiring as Brundage)
NL_VALS="0 0 0"                      # NL (Noise+Load)
L_VALS="0 0 1"                       # L  (Load)
SIGNAL_VALS="1 1 0"                  # Signal (also the end-of-run restore state)
