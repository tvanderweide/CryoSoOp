# site.env -- per-site / per-machine settings for the cryosoop orchestration scripts.
#
# THE ONE FILE TO EDIT when deploying at a new site (see README.md "Deploying at a
# new site" for the full checklist). Plain POSIX KEY=value, sourced with `set -a` by
# orchestration/radiometer_run.sh (and exported, so bbb_set_state.sh invoked from
# cryosoop's exec_hook inherits the BBB_* / GPIO / *_VALS values below).
#
# Not covered here (edit in place):
#   - config/radiometer_B210.yaml: RADIOMETER.gain (RF-chain-specific) and
#     DEVICE.device_args (add serial=... only if >1 USRP attached). All other YAML
#     keys are fixed science/device parameters.
#   - Nothing timezone-related: capture filenames and run folders are stamped in
#     UTC in code (independent of the OS timezone). Keep the clock NTP-synced
#     (timedatectl show-timesync); the processing side's site_config.json
#     "capture_tz" must be "UTC" for data from this binary.
#
# Bench use (scripts run standalone, without the wrapper):
#   set -a; . config/site.env; set +a; bbb_set_state.sh NL
# Every value here has an identical in-script default, so the scripts also run
# unchanged if this file is absent (SITE_ENV=/dev/null skips it explicitly).

# --- storage ---
MOUNT=/mnt/snowData                  # data mount point (pre-flight mountpoint check; only if REQUIRE_MOUNT=1)
DATA_DIR=/mnt/snowData/SDR/Data      # capture output root (passed to cryosoop as --save-loc)
REQUIRE_MOUNT=1                      # 1 = DATA_DIR must be under a dedicated mount ($MOUNT); 0 = plain local dir
MIN_FREE_GB=8                        # abort the run below this much free space [GB]
NVME_MIN_MBPS=400                    # pre-flight write-throughput floor [MB/s]

# --- post-collection transfer (optional; off by default) ---
# If TRANSFER_DIR is set, radiometer_run.sh relocates each finished run (rc 0/1) there
# after capture, preserving the <YYYYMMDD>/<HHMMSS>/ tree. Brundage leaves this empty --
# an external VM rsync-pulls DATA_DIR instead. TRANSFER_MODE is move|copy (move deletes
# the source only after a verified copy). See site_CSSL.env for a record-local-then-move example.
# TRANSFER_DIR=
TRANSFER_MODE=move

# --- run behavior ---
RX_TIMEOUT_SEC=1200                  # OS timeout around the WHOLE sequence [s] (>= 2x expected)
REBOOT_ON_FAIL=1                     # 1 = reboot Pi on fatal rc (production); 0 during bench bring-up
DEFAULT_GOV=ondemand                 # CPU governor restored after the run
# CRYOSOOP_BIN=/home/SDR/CryoSoOp/build/cryosoop   # optional; autodetected if unset
# CONFIG=/home/SDR/CryoSoOp/config/radiometer_B210.yaml  # optional; defaults to repo copy

# --- BeagleBone cal switch (bbb_set_state.sh) ---
BBB_HOST=root@192.168.1.101          # ssh target; needs passwordless key auth (BatchMode)
BBB_CONNECT_TIMEOUT=15               # ssh ConnectTimeout [s]
GPIO_PINS="49 115 27"                # cal-switch GPIO pins, order matters (per-state values are per-pin)
NL_VALS="0 0 0"                      # NL (Noise+Load)
L_VALS="0 0 1"                       # L  (Load)
SIGNAL_VALS="1 1 0"                  # Signal (also the end-of-run restore state)
